{
  "name": "factory-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/factory-server/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/factory-server"],
      "options": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File apps/factory-server/scripts/build-local.ps1",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File apps/factory-server/scripts/run-local.ps1",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "fix": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config apps/factory-server/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
